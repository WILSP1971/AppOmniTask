<?xml version="1.0" encoding="utf-8"?>
<!--
  Solo para depuración (§19): http://10.0.2.2:8000 (emulador de Android) es
  HTTP plano, y Android bloquea tráfico sin cifrar por defecto desde la API
  28. Este archivo vive en src/debug/, así que Flutter lo aplica solo a los
  builds de depuración — el build de release (HTTPS real) nunca lo incluye.
-->
<manifest xmlns:android="http://schemas.android.com/apk/res/android">
    <application android:usesCleartextTraffic="true" />
</manifest>
