# Flutter/Dart
.dart_tool/
.packages
build/
.flutter-plugins
.flutter-plugins-dependencies
.pub-cache/
.pub/
# pubspec.lock SÍ se versiona: esto es una app, no un paquete publicado —
# fijar versiones exactas da builds reproducibles entre máquinas/CI.

# Generado por freezed/json_serializable/riverpod_generator — se regenera
# con `dart run build_runner build --delete-conflicting-outputs`.
*.freezed.dart
*.g.dart

# Firebase (§20, SPEC-004): firebase_options.dart y google-services.json NO
# son secretos según la propia documentación de Firebase (identifican la app,
# el acceso se controla con reglas de seguridad, no con ocultar el archivo) —
# pero google-services.json se mantiene fuera del repo de todas formas porque
# main.dart no lo importa directamente (solo Gradle lo necesita en el build
# nativo, ya cubierto por el secret de android-release.yml). firebase_options.dart
# SÍ se versiona: main.dart lo importa de forma incondicional, así que sin él
# ni flutter analyze ni flutter test compilan en un checkout limpio (CI, o
# cualquier otra máquina).
android/app/google-services.json
ios/Runner/GoogleService-Info.plist

# IDE
.idea/
*.iml

# Específico de cada máquina / auto-generado por el toolchain de Flutter.
android/local.properties
android/app/src/main/java/io/flutter/plugins/GeneratedPluginRegistrant.java
